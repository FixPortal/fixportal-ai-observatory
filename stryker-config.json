{
  "stryker-config": {
    "solution": "AiObservatory.slnx",
    "project": "src/AiObservatory.Api/AiObservatory.Api.csproj",
    "test-projects": [
      "tests/AiObservatory.Api.Tests/AiObservatory.Api.Tests.csproj",
      "tests/AiObservatory.Data.Tests/AiObservatory.Data.Tests.csproj",
      "tests/AiObservatory.Ingest.Tests/AiObservatory.Ingest.Tests.csproj"
    ],
    "reporters": ["progress", "html", "json"],
    "report-file-name": "mutation-report",
    "mutation-level": "Standard",
    "coverage-analysis": "off",
    "test-runner": "mtp",
    "concurrency": 4,
    "thresholds": {
      "high": 80,
      "low": 70,
      "break": 0
    },
    "test-case-filter": "Category!=Integration",
    "mutate": ["**/*.cs"]
  }
}
