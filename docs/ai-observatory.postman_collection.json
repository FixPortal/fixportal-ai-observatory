              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/adversarial-review/runs",
              "host": ["{{base_url}}"],
              "path": ["adversarial-review", "runs"]
            }
          }
        },
        {
          "name": "List review runs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Observatory-Key", "value": "{{api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/adversarial-review/runs",
              "host": ["{{base_url}}"],
              "path": ["adversarial-review", "runs"]
            }
          }
        },
        {
          "name": "Get review stats",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Observatory-Key", "value": "{{api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/adversarial-review/stats",
              "host": ["{{base_url}}"],
              "path": ["adversarial-review", "stats"]
            },
            "description": "Returns aggregate stats across all review runs: total runs, cost, issues raised/accepted, acceptance rate."
          }
        }
      ]
    },
    {
      "name": "Dev (local only)",
      "description": "Development-only endpoints. Only available when the API runs in the Development environment (`ASPNETCORE_ENVIRONMENT=Development`). Not deployed to production.",
      "item": [
        {
          "name": "Seed sample data",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Observatory-Key", "value": "{{api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/dev/seed",
              "host": ["{{base_url}}"],
              "path": ["dev", "seed"]
            },
            "description": "Wipes the database and inserts 14 days of sample aggregates (Anthropic, Google, Copilot), two subscriptions, two budget rules, and three insights. The fastest way to see a populated dashboard locally."
          }
        }
      ]
    }
  ]
}
